{
  "name": "arashi-vscode",
  "displayName": "Arashi",
  "description": "Run Arashi workflows and manage worktrees from VS Code.",
  "version": "1.4.0",
  "publisher": "haphazarddev",
  "license": "MIT",
  "repository": "https://github.com/corwinm/arashi-vscode",
  "homepage": "https://arashi.haphazard.dev",
  "bugs": {
    "url": "https://github.com/corwinm/arashi-vscode/issues"
  },
  "icon": "images/arashi-logo.png",
  "engines": {
    "vscode": "^1.96.2"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "arashi",
    "git",
    "worktree",
    "vscode"
  ],
  "main": "./dist/extension.js",
  "activationEvents": [
    "onCommand:arashi.init",
    "onCommand:arashi.add",
    "onCommand:arashi.clone",
    "onCommand:arashi.create",
    "onCommand:arashi.install",
    "onCommand:arashi.update",
    "onCommand:arashi.shell",
    "onCommand:arashi.setup",
    "onCommand:arashi.prune",
    "onCommand:arashi.move",
    "onCommand:arashi.status",
    "onCommand:arashi.openWorkspaceRoot",
    "onCommand:arashi.openRepository",
    "onCommand:arashi.pull",
    "onCommand:arashi.sync",
    "onCommand:arashi.switch",
    "onCommand:arashi.remove",
    "onCommand:arashi.worktrees.refresh",
    "onCommand:arashi.worktrees.openRepo",
    "onCommand:arashi.worktrees.openStatusRepo",
    "onCommand:arashi.worktrees.openTerminal",
    "onCommand:arashi.worktrees.pullRepo",
    "onCommand:arashi.worktrees.cloneMissing",
    "onCommand:arashi.worktrees.switch",
    "onCommand:arashi.worktrees.remove",
    "onCommand:arashi.worktrees.addRepo",
    "onView:arashi.worktrees"
  ],
  "contributes": {
    "commands": [
      {
        "command": "arashi.init",
        "title": "Arashi: Init Workspace"
      },
      {
        "command": "arashi.add",
        "title": "Arashi: Add Repository"
      },
      {
        "command": "arashi.clone",
        "title": "Arashi: Clone Repositories"
      },
      {
        "command": "arashi.create",
        "title": "Arashi: Create Worktree",
        "icon": "$(add)"
      },
      {
        "command": "arashi.status",
        "title": "Arashi: Status"
      },
      {
        "command": "arashi.move",
        "title": "Arashi: Move Changes"
      },
      {
        "command": "arashi.prune",
        "title": "Arashi: Prune Stale Worktrees"
      },
      {
        "command": "arashi.setup",
        "title": "Arashi: Run Setup"
      },
      {
        "command": "arashi.shell",
        "title": "Arashi: Manage Shell Integration"
      },
      {
        "command": "arashi.update",
        "title": "Arashi: Update Arashi"
      },
      {
        "command": "arashi.install",
        "title": "Arashi: Install Binary"
      },
      {
        "command": "arashi.openWorkspaceRoot",
        "title": "Arashi: Open Workspace Root"
      },
      {
        "command": "arashi.openRepository",
        "title": "Arashi: Open Related Repository"
      },
      {
        "command": "arashi.pull",
        "title": "Arashi: Pull"
      },
      {
        "command": "arashi.sync",
        "title": "Arashi: Sync"
      },
      {
        "command": "arashi.switch",
        "title": "Arashi: Switch Worktree"
      },
      {
        "command": "arashi.remove",
        "title": "Arashi: Remove Worktree"
      },
      {
        "command": "arashi.worktrees.refresh",
        "title": "Refresh Arashi Worktrees",
        "icon": "$(refresh)"
      },
      {
        "command": "arashi.worktrees.openRepo",
        "title": "Open Repository",
        "icon": "$(go-to-file)"
      },
      {
        "command": "arashi.worktrees.openStatusRepo",
        "title": "Open Repository",
        "icon": "$(go-to-file)"
      },
      {
        "command": "arashi.worktrees.openTerminal",
        "title": "Open Terminal",
        "icon": "$(terminal)"
      },
      {
        "command": "arashi.worktrees.pullRepo",
        "title": "Pull Workspace",
        "icon": "$(repo-pull)"
      },
      {
        "command": "arashi.worktrees.cloneMissing",
        "title": "Clone Missing Repositories",
        "icon": "$(cloud-download)"
      },
      {
        "command": "arashi.worktrees.switch",
        "title": "Switch Worktree",
        "icon": "$(arrow-right)"
      },
      {
        "command": "arashi.worktrees.remove",
        "title": "Remove Worktree",
        "icon": "$(trash)"
      },
      {
        "command": "arashi.worktrees.addRepo",
        "title": "Add Repository",
        "icon": "$(repo-create)"
      }
    ],
    "views": {
      "explorer": [
        {
          "id": "arashi.worktrees",
          "name": "Arashi Worktrees"
        }
      ]
    },
    "menus": {
      "view/title": [
        {
          "command": "arashi.create",
          "when": "view == arashi.worktrees",
          "group": "navigation@1"
        },
        {
          "command": "arashi.worktrees.refresh",
          "when": "view == arashi.worktrees",
          "group": "navigation@2"
        }
      ],
      "view/item/context": [
        {
          "command": "arashi.worktrees.openRepo",
          "when": "view == arashi.worktrees && viewItem == arashi.repo",
          "group": "inline@1"
        },
        {
          "command": "arashi.worktrees.openStatusRepo",
          "when": "view == arashi.worktrees && viewItem =~ /arashi.statusRepo.*/",
          "group": "inline@1"
        },
        {
          "command": "arashi.worktrees.openTerminal",
          "when": "view == arashi.worktrees && viewItem =~ /arashi.statusRepo.*/",
          "group": "inline@2"
        },
        {
          "command": "arashi.worktrees.pullRepo",
          "when": "view == arashi.worktrees && (viewItem == arashi.statusRepo.behind || viewItem == arashi.statusRepo.diverged)",
          "group": "inline@3"
        },
        {
          "command": "arashi.worktrees.cloneMissing",
          "when": "view == arashi.worktrees && viewItem == arashi.statusRepo.error",
          "group": "inline@4"
        },
        {
          "command": "arashi.worktrees.switch",
          "when": "view == arashi.worktrees && viewItem == arashi.worktree",
          "group": "inline@1"
        },
        {
          "command": "arashi.worktrees.remove",
          "when": "view == arashi.worktrees && viewItem == arashi.worktree",
          "group": "inline@2"
        }
      ]
    },
    "configuration": {
      "title": "Arashi",
      "properties": {
        "arashi.binaryPath": {
          "type": "string",
          "default": "arashi",
          "description": "Path to the Arashi CLI binary used by this extension."
        },
        "arashi.workspaceRoot": {
          "type": "string",
          "default": "",
          "description": "Workspace root where Arashi commands run. Leave empty to use the current workspace folder."
        },
        "arashi.commandTimeoutMs": {
          "type": "number",
          "default": 120000,
          "minimum": 1000,
          "description": "Timeout in milliseconds for each Arashi command invocation."
        }
      }
    }
  },
  "scripts": {
    "build": "esbuild src/extension.ts --bundle --outdir=dist --platform=node --format=cjs --external:vscode --sourcemap",
    "watch": "pnpm run watch:build",
    "watch:build": "esbuild src/extension.ts --bundle --outdir=dist --platform=node --format=cjs --external:vscode --sourcemap --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "clean": "rm -rf dist",
    "lint": "tsc --noEmit",
    "test": "vitest run",
    "test:vscode": "pnpm run build && node scripts/run-vscode-integration-tests.mts",
    "vscode:prepublish": "pnpm run build",
    "verify:release": "node scripts/verify-release-metadata.mts",
    "release": "semantic-release",
    "package": "pnpm exec vsce package",
    "publish:vsce": "pnpm exec vsce publish --azure-credential",
    "publish:ovsx": "pnpm exec ovsx publish"
  },
  "packageManager": "pnpm@10.15.1",
  "devDependencies": {
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/commit-analyzer": "^13.0.1",
    "@semantic-release/exec": "^7.1.0",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^11.0.6",
    "@semantic-release/npm": "^12.0.2",
    "@semantic-release/release-notes-generator": "^14.1.0",
    "@types/node": "^22.13.1",
    "@types/vscode": "^1.96.0",
    "@vscode/test-electron": "^3.0.0",
    "@vscode/vsce": "^3.6.0",
    "conventional-changelog-conventionalcommits": "^8.0.0",
    "esbuild": "^0.25.0",
    "ovsx": "^0.10.5",
    "semantic-release": "^24.2.0",
    "typescript": "7.0.2",
    "vitest": "^3.2.0"
  }
}
